# Tronscan CLI Configuration
# Copy this file to .env and fill in your values

# Required
TRONSCAN_API_KEY=your-tron-pro-api-key-here

# Optional — defaults shown
TRONSCAN_BASE_URL=https://apilist.tronscanapi.com
TRONSCAN_TIMEOUT=30
TRONSCAN_LOG_LEVEL=INFO
TRONSCAN_CACHE_DIR=./cache
TRONSCAN_OUTPUT_DIR=./output
TRONSCAN_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# Retry settings
TRONSCAN_MAX_RETRIES=3
TRONSCAN_BACKOFF_MULTIPLIER=2.0
TRONSCAN_COURTESY_DELAY=0.1
